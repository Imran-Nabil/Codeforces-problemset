
#include <stdio.h>
#include<string.h>
int main(){
    char s[100];
    scanf("%s", s);
 
    int upper =0,lower =0;
    int length= strlen(s);
 
    for(int i =0; i<length ;i++) {
        if(s[i] >='A' && s[i] <='Z'){
            upper++;
        }
        else if (s[i] >= 'a' && s[i] <= 'z'){
          lower++;
        }
    }
 
    if (upper>lower){
        for (int i =0; i<length ;i++){
            if ((s[i] >='a') && (s[i] <='z')) {
                s[i] =s[i]-32;}
            }
         }
    else {
        for(int i =0; i<length ;i++){
            if (s[i] >='A' && s[i] <='Z') {
                s[i] =s[i]+32;
            }
         }
    }
 
    printf("%s\n",s);
    
    return 0;
}
